#! /opt/homebrew/bin/bash

# devtool
#
# A handy cli tool to for setting up files, folders, and env vars for Neovim/mise experimentation


# ---------------------------------------------------------
# BASH STRICT MODE
# ---------------------------------------------------------


# Docs:
#     https://www.gnu.org/software/bash/manual/html_node/The-Set-Builtin.html#The-Set-Builtin-1
#
# Options used:
#     -E [-o errtrace]:   Fail and exit if a function, command substitution, or subshell fails.
#     -e [-o errexit]:    Fail and exit if a command or command list fails.
#     -u [-o nounset]:    Fail and exit if an undeclared/uninitialized variable is referenced.
#     -o pipefail:        Fail and exit if any command in a pipeline fails.
set -Eeu -o pipefail


# ---------------------------------------------------------
# DEBUG
# ---------------------------------------------------------

SCRIPT_DEBUG=true


# ---------------------------------------------------------
# HELP
# ---------------------------------------------------------


help () {
cat << HELPDOC

USAGE:

  devtool [ help |
          [ install_neovim_lsps | lsp ] |
          [ setup_test_dir | testup ] |
          [ show_mise_config | cfg ] ]


SOURCE USAGE:

  source "\$(devtool [ binpath | cleanenv | shellenv | testenv ])"


ENV SETUP COMMANDS:

  All of these commands should have their output sourced by the user's interactive shell.

  binpath     - Export \$PATH with this project's bin directory appended.
  cleanenv    - Unset mise env vars.
  shellenv    - Export mise env vars and values for "production" usage. Calls cleanenv().
  testenv     - Export mise env vars with values for isolated testing. Calls cleanenv().


COMMANDS:

  install_neovim_lsps, lsp  - Install Neovim LSPs and deps with mise.
  setup_test_dir, testup    - Sets up a test directory in the project with the following structure:
                                \$NVIM_CONFIG_ROOT
                                └── mise                      NVIM_MISE_GLOBAL_CONFIG_ROOT
                                    └── config                NVIM_MISE_CONFIG_DIR
                                        └── mise.toml
  show_mise_config, cfg     - Show mise's configuration hierarchy.

HELPDOC
}


# ---------------------------------------------------------
# ENVIRONMENTAL CONFIGURATION
# ---------------------------------------------------------


# Constants for use as associative array keys
declare -r K_CFGD="config_dir"
declare -r K_GCFN="global_config_filename"
declare -r K_GCRT="global_config_root"
declare -r K_MENV="mise_env"
declare -r K_NVCFGD="nvim_config_root"
declare -r K_TESTD="test_dir"
declare -r K_TDN="test_dir_name"
declare -r K_TBKUP="test_dir_backup_dir"
declare -r K_TOOLD="tool_installs_dir"


# Use this for actual day-to-day usage
__shellenv_config () {
  # The global mise config filename
  #global_config_filename="mise.neovim.toml"
  local global_config_filename="mise.toml"

  # Equivalent of {{ config_root }} for Neovim.
  local nvim_config_root="${HOME}/.config/nvim"

  # Directory under {{ config_root }} that contains the isolated global mise config for Neovim.
  local global_config_root="${nvim_config_root}/mise"

  # mise will only load config files from child dirs of {{ config_root }}.
  # Config files in {{ config_root }} will be ignored.
  local config_dir="${global_config_root}/config"

  # Isolated install path for neovim related tools (LSPs and deps) under Neovim's data dir.
  local tool_installs_dir="${HOME}/.local/share/nvim"

  # No interest in serializing an associative array as a "return value."
  # Create a (-r)ead-only, (-g)lobal, (-A)ssociative array instead.
  declare -rgA SHELL_ENV_CONFIG=(
    [global_config_filename]="${global_config_filename}"
    [nvim_config_root]="${nvim_config_root}"
    [global_config_root]="${global_config_root}"
    [config_dir]="${config_dir}"
    [tool_installs_dir]="${tool_installs_dir}"
  )
}


# Use this to test and develop mise and Neovim integration
__testenv_config () {
  local work_dir; work_dir="$(dirname "$0")"

  local backup_dirname="test_dir_backups"

  local test_dir_name="test"
  local test_dir="${work_dir}/${test_dir_name}"

  # The global mise config filename
  #local global_config_filename="mise.neovim.toml"
  local global_config_filename="mise.toml"

  # Equivalent of {{ config_root }} for Neovim.
  local nvim_config_root="${test_dir}/config_root"

  # Directory under {{ config_root }} that contains the isolated global mise config for Neovim.
  local global_config_root="${nvim_config_root}/mise"

  # mise will only load config files from child dirs of {{ config_root }}.
  # Config files in {{ config_root }} will be ignored.
  local config_dir="${global_config_root}/config"

  # Isolated install path for neovim related tools (LSPs and deps) under Neovim's data dir.
  local tool_installs_dir="${test_dir}/installs"

  # No interest in serializing an associative array as a "return value."
  # Create a (-r)ead-only, (-g)lobal, (-A)ssociative array instead.
  declare -rgA TEST_ENV_CONFIG=(
    [backup_dirname]="${backup_dirname}"
    [test_dir_name]="${test_dir_name}"
    [test_dir]="${test_dir}"
    [global_config_filename]="${global_config_filename}"
    [nvim_config_root]="${nvim_config_root}"
    [global_config_root]="${global_config_root}"
    [config_dir]="${config_dir}"
    [tool_installs_dir]="${tool_installs_dir}"
  )
}


# ---------------------------------------------------------
# "PRIVATE" FUNCTIONS
# ---------------------------------------------------------


# echo to STDERR.
errcho () { echo -e "${*}" >&2; }


# log to STDERR with yellow text.
debug_log () { if $SCRIPT_DEBUG; then errcho "\e[33m${*}\e[0m" >&2; fi }


# Get the invocation string for the process running this script.
__get_shell_invocation() {
  local shell_pid="${1}"

  # The "=" after "command" disables header output
  ps -o command= "${shell_pid}"
}


# Get the fully qualified path to this project's bin directory from the
# relative path to this script.
#
# This used to live separately in the lib directory of this project.
# Not sure it's needed anymore.
__get_bin_path_from_lib_path () {
  local script_rel_path="${1}"

  local script_full_path
  local lib_dir_path
  local grandparent_path
  local bin_dir_path

  script_full_path="$(realpath "${script_rel_path}")"
  lib_dir_path="$(dirname "${script_full_path}")"
  grandparent_path="$(dirname "${lib_dir_path}")"
  bin_dir_path="${grandparent_path}/bin"

  errcho "script_rel_path:  [${script_rel_path}]"  # DEBUG DELETEME
  errcho "script_full_path: [${script_full_path}]" # DEBUG DELETEME
  errcho "lib_dir_path:     [${lib_dir_path}]"     # DEBUG DELETEME
  errcho "grandparent_path: [${grandparent_path}]" # DEBUG DELETEME
  errcho "bin_dir_path:     [${bin_dir_path}]"     # DEBUG DELETEME

  echo "${bin_dir_path}"
}

# Determine whether the shell is bash or zsh, determine the shell's invocation,
# and fetch a fully qualified path to this project's bin directory.
__get_bin_path () {
  local shell_invocation="${1}"

  if [[ $shell_invocation == *"bash"* ]]; then
    __get_bin_path_from_lib_path "${BASH_SOURCE[0]}"
  elif [[ $shell_invocation == *"zsh"* ]]; then
    __get_bin_path_from_lib_path "${(%):-%x}"
  else
    # Sorry POSIX shell. You've got no reliable way to retrieve a fully qualified path to a sourced script.
    errcho "Unsupported shell. Invocation: \"${shell_invocation}\""
    return 67
  fi
}


# Generate body text for the test directory's README file.
__generate_readme () {
  echo "When using MISE_CEILING_PATHS, mise will search directories under the directory specified as the ceiling for config files, but _NOT_ the ceiling direct itself."
}

# Generate the body of the mise config for testing/working with LSPs in Neovim.
__generate_mise_config () {
cat << 'EOF'
[tools]
node = "lts"
"aqua:LuaLS/lua-language-server" = "latest"
"aqua:koalaman/shellcheck"       = "latest"
"go:mvdan.cc/sh/v3/cmd/shfmt"    = "latest"
"npm:bash-language-server"       = { version = "latest", depends = ["aqua:koalaman/shellcheck", "go:mvdan.cc/sh/v3/cmd/shfmt"] }
"npm:prettier"                   = "latest"
"npm:prettier-plugin-awk"        = { version = "latest", depends = ["npm:prettier"] }
"npm:npm:prettier-plugin-awk"    = { version = "latest", depends = ["npm:prettier", "npm:prettier-plugin-awk"] }
EOF
}


# ---------------------------------------------------------
# SOURCED NEOVIM/MISE CONFIGURATION FUNCTIONS
# ---------------------------------------------------------


# Generate a command that adds this project's bin dir to $PATH.
# Suitable for sourcing.
binpath () {
  local sh_pid;    sh_pid=$$
  local sh_invoke; sh_invoke="$(__get_shell_invocation "${sh_pid}")"
  local bin_dir;   bin_dir="$(__get_bin_path "${sh_invoke}")"

  echo "export PATH=\"${PATH}:${bin_dir}\""
}


# Start clean with mise env vars.
cleanenv () {
  echo "unset MISE_CEILING_PATHS"
  echo "unset MISE_ENV"
  echo "unset MISE_GLOBAL_CONFIG_ROOT"
  echo "unset MISE_INSTALLS_DIR"
}


shellenv () {
  cleanenv

  # Config file must be named config.neovim.toml or mise.neovim.toml.
  #echo "export MISE_ENV=\"${SHELL_ENV_CONFIG[$K_MENV]}\""

  # Force the global config to live under Neovim's config tree by
  # making mise's {{ config_root }} live one directory below Neovim's.
  # Relative paths in environment directives are resolved against {{ config_root }}.
  echo "export MISE_GLOBAL_CONFIG_ROOT=\"${SHELL_ENV_CONFIG[$K_GCRT]}\""

  # Fully qualified path to the isolated global mise config for Neovim.
  echo "export MISE_GLOBAL_CONFIG_FILE=\"${SHELL_ENV_CONFIG[$K_CFGD]}/${SHELL_ENV_CONFIG[$K_GCFN]}\""

  # Prevents merging any config files found above the global config root.
  echo "export MISE_CEILING_PATHS=\"${SHELL_ENV_CONFIG[$K_GCRT]}\""

  # This is where tools are installed to when running mise install/use.
  # See:
  #     https://mise.jdx.dev/directories.html#local-share-mise-installs
  echo "export MISE_INSTALLS_DIR=\"${SHELL_ENV_CONFIG[$K_TOOLD]}\""
}


testenv () {
  cleanenv

  # Config file must be named config.neovim.toml or mise.neovim.toml.
  #echo "export MISE_ENV=\"${TEST_ENV_CONFIG[$K_MENV]}\""

  # Force the global config to live under Neovim's config tree by
  # making mise's {{ config_root }} live one directory below Neovim's
  # Relative paths in environment directives are resolved against {{ config_root }}.
  echo "export MISE_GLOBAL_CONFIG_ROOT=\"${TEST_ENV_CONFIG[$K_GCRT]}\""

  # Fully qualified path to the isolated global mise config for Neovim
  echo "export MISE_GLOBAL_CONFIG_FILE=\"${TEST_ENV_CONFIG[$K_CFGD]}/${TEST_ENV_CONFIG[$K_GCFN]}\""

  # Prevents merging any config files found above $NVIM_MISE_GLOBAL_CONFIG_ROOT.
  echo "export MISE_CEILING_PATHS=\"${TEST_ENV_CONFIG[$K_GCRT]}\""

  # This is where tools are installed to when running mise install/use.
  # See:
  #     https://mise.jdx.dev/directories.html#local-share-mise-installs
  echo "export MISE_INSTALLS_DIR=\"${TEST_ENV_CONFIG[$K_TOOLD]}\""
}


# ---------------------------------------------------------
# SUB COMMAND FUNCTIONS
# ---------------------------------------------------------


# Install Neovim LSPs and deps with mise.
install_neovim_lsps () { mise install; }

# Short name for the install_neovim_lsps command.
lsp () { install_neovim_lsps; }


# Show mise's configuration hierarchy
show_mise_config () { mise config ls; }

# Short name for the show_mise_config command.
cfg () { show_mise_config; }


# Config dir structucture:
# $NVIM_CONFIG_ROOT
# └── mise                      NVIM_MISE_GLOBAL_CONFIG_ROOT
#     └── config                NVIM_MISE_CONFIG_DIR
#         └── mise.toml
setup_test_dir () {
  local backup_dirname="${TEST_ENV_CONFIG[$K_TBKUP]}"

  # Check if test directory exists. If so, back it up and delete the tree
  if [ -d "${TEST_ENV_CONFIG[$K_TESTD]}" ]; then
    local timestamp; timestamp=$(date +%s)
    local backup_filename="${TEST_ENV_CONFIG[$K_TDN]}_${timestamp}.tgz"

    gtar -czvf "${backup_filename}" "${TEST_ENV_CONFIG[$K_TDN]}"
    mv "${backup_filename}" "${TEST_ENV_CONFIG[$K_TBKUP]}"
    rm -rf "${TEST_ENV_CONFIG[$K_TDN]}"

    echo "Found \"${TEST_ENV_CONFIG[$K_TESTD]}\". Backed up to \"${TEST_ENV_CONFIG[$K_TBKUP]}/${backup_filename}\""
  fi

  # Create the folder structure
  mkdir -p "${TEST_ENV_CONFIG[$K_CFGD]}"
  mkdir -p "${TEST_ENV_CONFIG[$K_TOOLD]}"

  # Create README for config_root
  __generate_readme > "${TEST_ENV_CONFIG[$K_NVCFGD]}/README.txt"

  # Create mise config file
  __generate_mise_config > "${TEST_ENV_CONFIG[$K_CFGD]}/${TEST_ENV_CONFIG[$K_GCFN]}"
}

# Short name for the setup_test_dir command.
testup () { setup_test_dir; }


# ---------------------------------------------------------
# EXECUTE THE SUB-COMMAND
# ---------------------------------------------------------

# Populate read-only associative arrays.
__shellenv_config
__testenv_config

# $@ should match one of the sub-command function names above.
"${@}"
